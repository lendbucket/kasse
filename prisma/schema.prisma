  service                   Service?     @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([locationId], map: "idx_cancelpol_location", where: raw("(\"locationId\" IS NOT NULL)"))
  @@index([organizationId, isActive], map: "idx_cancelpol_org")
  @@index([serviceId], map: "idx_cancelpol_service", where: raw("(\"serviceId\" IS NOT NULL)"))
}

model BookingWindow {
