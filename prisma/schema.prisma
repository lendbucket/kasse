generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════
// ROLE ENUM (ABO-002: database-level role enforcement)
// ═══════════════════════════════════════════

enum Role {
  SUPERADMIN
  OWNER
  MANAGER
  STAFF
  STAFF_VIEW_ONLY
  CLIENT
  FRANCHISE_OWNER
  ACCOUNTANT
  BUSINESS_PARTNER
}

// ═══════════════════════════════════════════
// GROUP LEVEL ENUM (P0.A.13: organization hierarchy)
// ═══════════════════════════════════════════

enum GroupLevel {
  REGION
  BRAND
  CONCEPT
}

// ═══════════════════════════════════════════
// VERTICAL ID ENUM (P0.C.1: vertical configuration system)
// ═══════════════════════════════════════════

enum VerticalId {
  salon
  barbershop
  nail_salon
  restaurant
  bar
  gym
  yoga_studio
  pilates_studio
  massage
  med_spa
  auto_detailing
  auto_repair
  pet_grooming
  veterinary
  tattoo
  retail
  food_truck
  cafe
  bakery
  catering
  cleaning
  photography
  tutoring
  childcare
  coworking
  sports_training
  beauty_school
  brow_studio
  lash_studio
  tanning_studio
  dance_studio
  martial_arts
  crossfit
  chiropractic
  physical_therapy
  general
}

// ═══════════════════════════════════════════
// PLAN TIER ENUM (P0.D.1: plan tier system)
// ═══════════════════════════════════════════

enum PlanTier {
  FREE
  PLUS
  PREMIUM
  ENTERPRISE
}

// ═══════════════════════════════════════════
// DEPOSIT TYPE ENUM (P0.G.1: service deposit type)
// ═══════════════════════════════════════════

enum DepositType {
  FIXED_AMOUNT
  PERCENTAGE
}

// ═══════════════════════════════════════════
// ORGANIZATION GROUPS (P0.A.13: multi-level hierarchy)
// ═══════════════════════════════════════════

model OrganizationGroup {
  id              String              @id @default(cuid())
  name            String
  level           GroupLevel
  parentGroupId   String?
  parentGroup     OrganizationGroup?  @relation("GroupHierarchy", fields: [parentGroupId], references: [id], onDelete: SetNull)
  childGroups     OrganizationGroup[] @relation("GroupHierarchy")
  permissionSetId String?
  permissionSet   PermissionSet?      @relation("GroupPermissionSet", fields: [permissionSetId], references: [id], onDelete: SetNull)
  organizationId  String
  organization    Organization        @relation("OrgGroups", fields: [organizationId], references: [id], onDelete: Cascade)
  locations       Location[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([parentGroupId])
  @@index([level])
  @@index([permissionSetId])
  @@index([organizationId])
}

// ═══════════════════════════════════════════
// ORGANIZATIONS & FRANCHISING
// ═══════════════════════════════════════════

model Organization {
  id                     String                @id @default(cuid())
  name                   String
  slug                   String                @unique
  logoUrl                String?
  primaryColor           String?               @default("#606E74")
  email                  String?
  phone                  String?
  website                String?
  address                String?
  city                   String?
  state                  String?
  zip                    String?
  country                String                @default("US")
  timezone               String                @default("America/Chicago")
  language               String                @default("en")
  isFranchise            Boolean               @default(false)
  franchiseFeeType       String?
  franchiseFeeValue      Float?
  techFeeType            String?
  techFeeValue           Float?
  marketingFeeType       String?
  marketingFeeValue      Float?
  parentOrgId            String?
  parentOrg              Organization?         @relation("FranchiseHierarchy", fields: [parentOrgId], references: [id])
  childOrgs              Organization[]        @relation("FranchiseHierarchy")
  plan                   String                @default("starter")
  planStatus             String                @default("trial")
  trialEndsAt            DateTime?
  stripeCustomerId       String?
  stripeSubId            String?
  salonTransactId        String?
  legalName              String?
  businessStructure      String?
  ein                    String?
  stateOfFormation       String?
  yearEstablished        Int?
  businessType           String?
  description            String?
  teamSize               String?
  sourceSystem           String?
  dbaName                String?
  ownerFirstName         String?
  ownerLastName          String?
  ownerDob               String?
  ownerSsnLast4          String?
  ownerTitle             String?
  ownershipPercentage    Int?
  ownerAddress           String?
  bankAccountHolder      String?
  bankRoutingNumber      String?
  bankAccountNumber      String?
  bankAccountType        String?
  fundingSpeed           String?
  monthlyVolume          String?
  avgTransaction         String?
  paymentMethods         String[]
  applicationStatus      String?               @default("not_started")
  applicationSubmittedAt DateTime?
  onboardingStep         Int                   @default(0)
  onboardingCompleted    Boolean               @default(false)
  verticalId             VerticalId            @default(salon)
  verticalConfigOverride Json?
  themeOverride          Json?
  planTier               PlanTier              @default(FREE)
  enabledAddons          String[]              @default([])
  planEffectiveAt        DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  locations              Location[]
  users                  User[]
  staff                  Staff[]
  clients                Client[]
  services               Service[]
  appointments           Appointment[]
  transactions           Transaction[]
  giftCards              GiftCard[]
  loyaltyProgram         LoyaltyProgram?
  memberships            Membership[]
  campaigns              Campaign[]
  waitlistEntries        WaitlistEntry[]
  importJobs             ImportJob[]
  permissionSets         PermissionSet[]
  apiKeys                ApiKey[]
  webhooks               Webhook[]
  devices                Device[]
  businessSettings       BusinessSettings?
  aiReceptionistConfig   AiReceptionistConfig?
  messages               Message[]
  organizationGroups     OrganizationGroup[]   @relation("OrgGroups")
  colorFormulas          ColorFormula[]
  consentSignatures      ConsentSignature[]
  recurringSeries        RecurringSeries[]
  cancellationPolicies   CancellationPolicy[]

  @@index([verticalId])
  @@index([planTier])
}

// ═══════════════════════════════════════════
// AUTH & USERS
// ═══════════════════════════════════════════

model User {
  id                 String                     @id @default(cuid())
  name               String?
  email              String                     @unique
  emailVerified      DateTime?
  emailVerifyToken   String?
  emailVerifyExp     DateTime?
  password           String?
  image              String?
  role               Role                       @default(STAFF)
  organizationId     String?
  organization       Organization?              @relation(fields: [organizationId], references: [id])
  locationId         String?
  customRoleId       String?
  customRole         PermissionSet?             @relation("UserCustomRole", fields: [customRoleId], references: [id], onDelete: SetNull)
  isActive           Boolean                    @default(true)
  lastLoginAt        DateTime?
  passwordResetToken String?
  passwordResetExp   DateTime?
  twoFactorEnabled   Boolean                    @default(false)
  twoFactorSecret    String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  accounts           Account[]
  sessions           Session[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  staff              Staff?                     @relation("UserStaff")
  bookedAppointments Appointment[]              @relation("BookedByUser")
  statusChanges      AppointmentStatusHistory[] @relation("StatusChangedByUser")

  @@index([customRoleId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ═══════════════════════════════════════════
// LOCATIONS
// ═══════════════════════════════════════════

model Location {
  id                      String               @id @default(cuid())
  organizationId          String
  organization            Organization         @relation(fields: [organizationId], references: [id])
  name                    String
  address                 String?
  city                    String?
  state                   String?
  zip                     String?
  phone                   String?
  email                   String?
  timezone                String               @default("America/Chicago")
  isActive                Boolean              @default(true)
  taxRate                 Float                @default(8.25)
  logoUrl                 String?
  coverImageUrl           String?
  lat                     Float?
  lng                     Float?
  geofenceRadius          Int                  @default(100)
  businessHours           Json?
  groupId                 String?
  group                   OrganizationGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  salonTransactLocationId String?
  createdAt               DateTime             @default(now())
  staff                   Staff[]
  clients                 Client[]
  services                Service[]
  appointments            Appointment[]
  transactions            Transaction[]
  devices                 Device[]
  waitlistEntries         WaitlistEntry[]
  serviceLocations        ServiceLocation[]
  stylistSchedules        StylistSchedule[]
  bookingWindow           BookingWindow?
  recurringSeries         RecurringSeries[]
  cancellationPolicies    CancellationPolicy[]

  @@index([groupId])
}

// ═══════════════════════════════════════════
// STAFF
// ═══════════════════════════════════════════

model Staff {
  id                    String                     @id @default(cuid())
  organizationId        String
  organization          Organization               @relation(fields: [organizationId], references: [id])
  locationId            String
  location              Location                   @relation(fields: [locationId], references: [id])
  userId                String?                    @unique
  user                  User?                      @relation("UserStaff", fields: [userId], references: [id], onDelete: SetNull)
  name                  String
  email                 String?
  phone                 String?
  role                  String                     @default("stylist")
  jobTitle              String?
  commissionType        String                     @default("percentage")
  commissionRate        Float                      @default(40)
  isActive              Boolean                    @default(true)
  color                 String?
  bio                   String?
  avatarUrl             String?
  licenseNumber         String?
  licenseExpiry         DateTime?
  hireDate              DateTime?
  goals                 Json?
  softDeletedAt         DateTime?
  bufferOverrideMinutes Json?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  appointments          Appointment[]
  clockEvents           ClockEvent[]
  performanceStats      PerformanceStat[]
  messages              Message[]
  serviceStaffOverrides ServiceStaffOverride[]
  stylistServices       StylistService[]
  stylistSchedules      StylistSchedule[]
  scheduleExceptions    StylistScheduleException[]
  colorFormulas         ColorFormula[]
  appointmentItems      AppointmentItem[]
  bookedAppointments    Appointment[]              @relation("BookedByStaff")
  statusChanges         AppointmentStatusHistory[] @relation("StatusChangedByStaff")
  recurringSeries       RecurringSeries[]

  @@index([organizationId, isActive])
}

model ClockEvent {
  id             String   @id @default(cuid())
  staffId        String
  staff          Staff    @relation(fields: [staffId], references: [id])
  type           String
  timestamp      DateTime @default(now())
  lat            Float?
  lng            Float?
  withinGeofence Boolean  @default(false)
  ipAddress      String?
}

model PerformanceStat {
  id           String   @id @default(cuid())
  staffId      String
  staff        Staff    @relation(fields: [staffId], references: [id])
  periodStart  DateTime
  periodEnd    DateTime
  revenue      Float    @default(0)
  transactions Int      @default(0)
  tips         Float    @default(0)
  commission   Float    @default(0)
  rebooks      Int      @default(0)
  newClients   Int      @default(0)
  retailSales  Float    @default(0)
  createdAt    DateTime @default(now())
}

// ═══════════════════════════════════════════
// CLIENTS
// ═══════════════════════════════════════════

model Client {
  id                      String              @id @default(cuid())
  organizationId          String
  organization            Organization        @relation(fields: [organizationId], references: [id])
  locationId              String?
  location                Location?           @relation(fields: [locationId], references: [id])
  name                    String
  firstName               String?
  lastName                String?
  email                   String?
  phone                   String?
  altPhone                String?
  dateOfBirth             DateTime?
  gender                  String?
  address                 String?
  city                    String?
  state                   String?
  zip                     String?
  notes                   String?
  preferredStaffId        String?
  genderPref              String?
  referralSource          String?
  referredById            String?
  tags                    String[]
  isActive                Boolean             @default(true)
  marketingOptIn          Boolean             @default(false)
  smsOptIn                Boolean             @default(false)
  emailOptIn              Boolean             @default(false)
  loyaltyPoints           Int                 @default(0)
  totalSpent              Float               @default(0)
  visitCount              Int                 @default(0)
  lastVisitAt             DateTime?
  cardOnFile              Boolean             @default(false)
  stripeCustomerId        String?
  allergies               Json?
  vipStatus               Boolean             @default(false)
  relationshipScore       Int                 @default(0)
  preferredLanguage       String              @default("en")
  preferredContactChannel String              @default("SMS")
  totalLifetimeValue      Int                 @default(0)
  softDeletedAt           DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  familyMembers           FamilyMember[]
  appointments            Appointment[]
  transactions            Transaction[]
  giftCards               GiftCard[]
  memberships             ClientMembership[]
  loyaltyHistory          LoyaltyEvent[]
  formSubmissions         FormSubmission[]
  waitlistEntries         WaitlistEntry[]
  campaigns               CampaignRecipient[]
  messages                Message[]
  colorFormulas           ColorFormula[]
  consentSignatures       ConsentSignature[]
  recurringSeries         RecurringSeries[]

  @@index([organizationId, isActive])
}

model FamilyMember {
  id              String    @id @default(cuid())
  primaryClientId String
  primaryClient   Client    @relation(fields: [primaryClientId], references: [id])
  name            String
  relationship    String?
  dateOfBirth     DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
}

// ═══════════════════════════════════════════
// SERVICES
// ═══════════════════════════════════════════

model Service {
  id                        String                 @id @default(cuid())
  organizationId            String
  organization              Organization           @relation(fields: [organizationId], references: [id])
  locationId                String?
  location                  Location?              @relation(fields: [locationId], references: [id])
  name                      String
  description               String?
  category                  String?
  price                     Float
  duration                  Int
  bufferTime                Int                    @default(0)
  isAddon                   Boolean                @default(false)
  addonAddsTime             Boolean                @default(false)
  maxAddonTime              Int?
  isActive                  Boolean                @default(true)
  taxable                   Boolean                @default(true)
  color                     String?
  imageUrl                  String?
  depositRequired           Boolean                @default(false)
  depositType               DepositType?
  depositValueCents         Int?
  productCost               Int?
  consumableCost            Int?
  targetMarginPct           Int?
  processingMinutes         Int?
  addOnVisibleOnBookingMenu Boolean                @default(true)
  bookableByCustomers       Boolean                @default(true)
  bookableByStaff           Boolean                @default(true)
  requiresConsultation      Boolean                @default(false)
  requiresConsent           Boolean                @default(false)
  softDeletedAt             DateTime?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  appointments              Appointment[]
  serviceLocations          ServiceLocation[]
  serviceStaffOverrides     ServiceStaffOverride[]
  stylistServices           StylistService[]
  consentSignatures         ConsentSignature[]
  appointmentItems          AppointmentItem[]
  recurringSeries           RecurringSeries[]
  cancellationPolicies      CancellationPolicy[]

  @@index([organizationId, locationId, isActive])
  @@index([organizationId, isAddon, isActive])
}

// ═══════════════════════════════════════════
// SERVICE OVERRIDES (P0.G.1: per-location + per-staff pricing/duration)
// ═══════════════════════════════════════════

model ServiceLocation {
  id                      String   @id @default(cuid())
  serviceId               String
  service                 Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  locationId              String
  location                Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  priceOverrideCents      Int?
  durationOverrideMinutes Int?
  isAvailable             Boolean  @default(true)
  pendingPriceApproval    Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @default(now()) @updatedAt

  @@unique([serviceId, locationId])
  @@index([serviceId])
  @@index([locationId])
}

model ServiceStaffOverride {
  id              String   @id @default(cuid())
  serviceId       String
  service         Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staffId         String
  staff           Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  priceCents      Int?
  durationMinutes Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@unique([serviceId, staffId])
  @@index([serviceId])
  @@index([staffId])
}

model StylistService {
  id         String   @id @default(cuid())
  staffId    String
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  skillLevel String?
  createdAt  DateTime @default(now())

  @@unique([staffId, serviceId])
  @@index([staffId])
  @@index([serviceId])
}

// ═══════════════════════════════════════════
// COLOR FORMULAS (P0.G.1: per-client formula history)
// ═══════════════════════════════════════════

model ColorFormula {
  id                 String       @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId           String
  client             Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointmentId      String?
  appointment        Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  staffId            String
  staff              Staff        @relation(fields: [staffId], references: [id], onDelete: Restrict)
  formulaVersion     Int          @default(1)
  formulaIngredients Json
  processingMinutes  Int?
  resultNotes        String?
  beforePhotoUrl     String?
  afterPhotoUrl      String?
  allergyChecked     Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @default(now()) @updatedAt

  @@index([clientId, createdAt(sort: Desc)])
  @@index([organizationId])
  @@index([appointmentId])
}

// ═══════════════════════════════════════════
// CONSENT SIGNATURES (P0.G.1: chemical service waivers)
// ═══════════════════════════════════════════

/// Immutable audit record — signatures don't change after creation. No updatedAt field intentional.
model ConsentSignature {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId         String
  client           Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId        String?
  service          Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  consentType      String
  signedAt         DateTime     @default(now())
  signedDocUrl     String?
  signatureDataUrl String?
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime?

  @@index([clientId, signedAt(sort: Desc)])
  @@index([organizationId])
}

// ═══════════════════════════════════════════
// STYLIST SCHEDULING (P0.G.1: weekly recurring + exceptions)
// ═══════════════════════════════════════════

model StylistSchedule {
  id                 String    @id @default(cuid())
  staffId            String
  staff              Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  locationId         String
  location           Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  dayOfWeek          Int
  startTime          DateTime  @db.Time()
  endTime            DateTime  @db.Time()
  isWorking          Boolean   @default(true)
  effectiveStartDate DateTime  @db.Date
  effectiveEndDate   DateTime? @db.Date
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  @@unique([staffId, dayOfWeek, effectiveStartDate])
  @@index([staffId, dayOfWeek])
  @@index([staffId, effectiveStartDate, effectiveEndDate])
  @@index([locationId])
}

model StylistScheduleException {
  id        String    @id @default(cuid())
  staffId   String
  staff     Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date      DateTime  @db.Date
  startTime DateTime? @db.Time()
  endTime   DateTime? @db.Time()
  isWorking Boolean   @default(false)
  reason    String?
  createdAt DateTime  @default(now())

  @@unique([staffId, date])
  @@index([staffId, date])
}

// ═══════════════════════════════════════════
// APPOINTMENTS
// ═══════════════════════════════════════════

model Appointment {
  id                          String                     @id @default(cuid())
  organizationId              String
  organization                Organization               @relation(fields: [organizationId], references: [id])
  locationId                  String
  location                    Location                   @relation(fields: [locationId], references: [id])
  clientId                    String?
  client                      Client?                    @relation(fields: [clientId], references: [id])
  staffId                     String
  staff                       Staff                      @relation(fields: [staffId], references: [id])
  serviceId                   String?
  service                     Service?                   @relation(fields: [serviceId], references: [id])
  clientName                  String?
  serviceName                 String?
  price                       Float?
  depositPaid                 Float                      @default(0)
  status                      String                     @default("scheduled")
  startTime                   DateTime
  endTime                     DateTime
  notes                       String?
  internalNotes               String?
  isWalkIn                    Boolean                    @default(false)
  checkoutCode                String?                    @unique
  checkedInAt                 DateTime?
  completedAt                 DateTime?
  cancelledAt                 DateTime?
  cancelReason                String?
  reminderSent                Boolean                    @default(false)
  confirmationSent            Boolean                    @default(false)
  rebookedFrom                String?
  seriesId                    String?
  series                      RecurringSeries?           @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  bookingSource               String                     @default("STAFF")
  bookedByUserId              String?
  bookedByUser                User?                      @relation("BookedByUser", fields: [bookedByUserId], references: [id], onDelete: SetNull)
  bookedByStaffId             String?
  bookedByStaff               Staff?                     @relation("BookedByStaff", fields: [bookedByStaffId], references: [id], onDelete: SetNull)
  preAuthHoldCents            Int?
  preAuthHoldStatus           String?
  /// Pre-auth transaction ID from SalonTransact (which routes to Payroc or future processors).
  /// Processor-agnostic naming intentional — Kasse calls SalonTransact, not Payroc directly.
  preAuthHoldTxId             String?
  noShowFeeAppliedCents       Int?
  cancellationFeeAppliedCents Int?
  consentSignatureIds         String[]                   @default([])
  estimatedTotalCents         Int?
  estimatedTotalMinutes       Int?
  isFirstVisit                Boolean                    @default(false)
  formulaIds                  String[]                   @default([])
  softDeletedAt               DateTime?
  addons                      AppointmentAddon[]
  items                       AppointmentItem[]
  statusHistory               AppointmentStatusHistory[]
  formSubmissions             FormSubmission[]
  colorFormulas               ColorFormula[]
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt

  @@index([organizationId, locationId, startTime])
  @@index([organizationId, staffId, startTime])
  @@index([clientId])
  @@index([seriesId])
  @@index([organizationId, bookingSource])
}

model AppointmentItem {
  id                       String      @id @default(cuid())
  appointmentId            String
  appointment              Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId                String
  service                  Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staffId                  String
  staff                    Staff       @relation(fields: [staffId], references: [id], onDelete: Restrict)
  scheduledStart           DateTime
  scheduledEnd             DateTime
  actualStart              DateTime?
  actualEnd                DateTime?
  priceAtBookingCents      Int
  durationAtBookingMinutes Int
  isPrimary                Boolean     @default(false)
  isAddOn                  Boolean     @default(false)
  displayOrder             Int         @default(0)
  notes                    String?
  status                   String      @default("SCHEDULED")
  completedAt              DateTime?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @default(now()) @updatedAt

  @@index([appointmentId])
  @@index([serviceId])
  @@index([staffId, scheduledStart])
  @@index([appointmentId, status])
}

model AppointmentStatusHistory {
  id               String      @id @default(cuid())
  appointmentId    String
  appointment      Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  previousStatus   String?
  newStatus        String
  changedByUserId  String?
  changedByUser    User?       @relation("StatusChangedByUser", fields: [changedByUserId], references: [id], onDelete: SetNull)
  changedByStaffId String?
  changedByStaff   Staff?      @relation("StatusChangedByStaff", fields: [changedByStaffId], references: [id], onDelete: SetNull)
  changeReason     String?
  changeSource     String      @default("STAFF")
  createdAt        DateTime    @default(now())

  @@index([appointmentId, createdAt(sort: Desc)])
}

model AppointmentAddon {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  name          String
  price         Float
  duration      Int         @default(0)
  addedBy       String?
  createdAt     DateTime    @default(now())
}

// ═══════════════════════════════════════════
// RECURRING SERIES (P0.G.2: recurring appointments)
// ═══════════════════════════════════════════

model RecurringSeries {
  id                   String        @id @default(cuid())
  organizationId       String
  organization         Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId           String
  location             Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  clientId             String
  client               Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staffId              String
  staff                Staff         @relation(fields: [staffId], references: [id], onDelete: Restrict)
  primaryServiceId     String
  primaryService       Service       @relation(fields: [primaryServiceId], references: [id], onDelete: Restrict)
  frequency            String
  customIntervalDays   Int?
  dayOfWeek            Int?
  preferredTime        DateTime      @db.Time()
  startDate            DateTime      @db.Date
  endDate              DateTime?     @db.Date
  maxOccurrences       Int?
  occurrencesGenerated Int           @default(0)
  lastGeneratedThrough DateTime?     @db.Date
  status               String        @default("ACTIVE")
  pausedReason         String?
  pausedUntil          DateTime?     @db.Date
  notes                String?
  appointments         Appointment[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @default(now()) @updatedAt

  @@index([organizationId, status])
  @@index([clientId])
  @@index([staffId, status])
  @@index([lastGeneratedThrough])
}

// ═══════════════════════════════════════════
// CANCELLATION POLICY (P0.G.2: per-service cancellation rules)
// ═══════════════════════════════════════════

model CancellationPolicy {
  id                        String       @id @default(cuid())
  organizationId            String
  organization              Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceId                 String?
  service                   Service?     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  locationId                String?
  location                  Location?    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  windowHours               Int          @default(24)
  cancellationFeeFixedCents Int?
  cancellationFeePercentage Int?
  cancellationFeeChargeType String       @default("FIXED")
  noShowFeeFixedCents       Int?
  noShowFeePercentage       Int?
  noShowFeeChargeType       String       @default("FIXED")
  policyText                String?
  requirePreAuth            Boolean      @default(false)
  preAuthAmountCents        Int?
  isActive                  Boolean      @default(true)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @default(now()) @updatedAt

  @@index([organizationId, isActive])
  @@index([serviceId])
  @@index([locationId])
}

// ═══════════════════════════════════════════
// BOOKING WINDOW (P0.G.2: per-location booking constraints)
// ═══════════════════════════════════════════

model BookingWindow {
  id                               String   @id @default(cuid())
  locationId                       String   @unique
  location                         Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  maxDaysAhead                     Int      @default(60)
  minHoursAhead                    Int      @default(1)
  slotGranularityMinutes           Int      @default(15)
  allowSameDayBooking              Boolean  @default(true)
  allowOnlineBooking               Boolean  @default(true)
  requireDepositForNewClients      Boolean  @default(false)
  requireConsultationForNewClients Boolean  @default(false)
  bufferBetweenAppointmentsMinutes Int      @default(0)
  maxConcurrentBookingsPerClient   Int      @default(5)
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @default(now()) @updatedAt
}

// ═══════════════════════════════════════════
// TRANSACTIONS & PAYMENTS
// ═══════════════════════════════════════════

model Transaction {
  id              String            @id @default(cuid())
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id])
  locationId      String
  location        Location          @relation(fields: [locationId], references: [id])
  appointmentId   String?
  clientId        String?
  client          Client?           @relation(fields: [clientId], references: [id])
  staffId         String?
  clientName      String?
  subtotal        Float
  tax             Float             @default(0)
  tip             Float             @default(0)
  discount        Float             @default(0)
  giftCardAmount  Float             @default(0)
  loyaltyAmount   Float             @default(0)
  depositApplied  Float             @default(0)
  total           Float
  paymentMethod   String?
  salonTransactId String?
  stripePaymentId String?
  status          String            @default("completed")
  receiptSent     Boolean           @default(false)
  receiptEmail    String?
  notes           String?
  items           TransactionItem[]
  createdAt       DateTime          @default(now())
}

model TransactionItem {
  id             String      @id @default(cuid())
  transactionId  String
  transaction    Transaction @relation(fields: [transactionId], references: [id])
  name           String
  type           String
  price          Float
  quantity       Int         @default(1)
  staffId        String?
  commissionRate Float?
  createdAt      DateTime    @default(now())
}

// ═══════════════════════════════════════════
// GIFT CARDS
// ═══════════════════════════════════════════

model GiftCard {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id])
  clientId       String?
  client         Client?              @relation(fields: [clientId], references: [id])
  code           String               @unique
  initialBalance Float
  balance        Float
  isActive       Boolean              @default(true)
  expiresAt      DateTime?
  purchasedAt    DateTime             @default(now())
  redemptions    GiftCardRedemption[]
}

model GiftCardRedemption {
  id            String   @id @default(cuid())
  giftCardId    String
  giftCard      GiftCard @relation(fields: [giftCardId], references: [id])
  amount        Float
  transactionId String?
  redeemedAt    DateTime @default(now())
}

// ═══════════════════════════════════════════
// LOYALTY
// ═══════════════════════════════════════════

model LoyaltyProgram {
  id              String       @id @default(cuid())
  organizationId  String       @unique
  organization    Organization @relation(fields: [organizationId], references: [id])
  name            String       @default("Rewards")
  pointsPerDollar Float        @default(1)
  dollarPerPoint  Float        @default(0.01)
  minRedemption   Int          @default(100)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
}

model LoyaltyEvent {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  type      String
  points    Int
  balance   Int
  note      String?
  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════════
// MEMBERSHIPS
// ═══════════════════════════════════════════

model Membership {
  id               String             @id @default(cuid())
  organizationId   String
  organization     Organization       @relation(fields: [organizationId], references: [id])
  name             String
  description      String?
  price            Float
  billingCycle     String             @default("monthly")
  discountType     String?
  discountValue    Float?
  servicesIncluded Json?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  clients          ClientMembership[]
}

model ClientMembership {
  id              String     @id @default(cuid())
  clientId        String
  client          Client     @relation(fields: [clientId], references: [id])
  membershipId    String
  membership      Membership @relation(fields: [membershipId], references: [id])
  status          String     @default("active")
  startDate       DateTime   @default(now())
  nextBillingDate DateTime?
  stripeSubId     String?
  createdAt       DateTime   @default(now())
}

// ═══════════════════════════════════════════
// WAITLIST
// ═══════════════════════════════════════════

model WaitlistEntry {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  locationId       String
  location         Location     @relation(fields: [locationId], references: [id])
  clientId         String?
  client           Client?      @relation(fields: [clientId], references: [id])
  clientName       String?
  clientPhone      String?
  clientEmail      String?
  serviceId        String?
  serviceName      String?
  preferredStaffId String?
  preferredDate    DateTime?
  flexibleDates    Boolean      @default(true)
  status           String       @default("waiting")
  notifiedAt       DateTime?
  expiresAt        DateTime?
  notes            String?
  createdAt        DateTime     @default(now())
}

// ═══════════════════════════════════════════
// MARKETING & CAMPAIGNS
// ═══════════════════════════════════════════

model Campaign {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id])
  name           String
  type           String
  channel        String
  status         String              @default("draft")
  subject        String?
  content        String?
  htmlContent    String?
  segmentRules   Json?
  scheduledAt    DateTime?
  sentAt         DateTime?
  sentCount      Int                 @default(0)
  openCount      Int                 @default(0)
  clickCount     Int                 @default(0)
  triggerType    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  recipients     CampaignRecipient[]
}

model CampaignRecipient {
  id         String    @id @default(cuid())
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id])
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id])
  status     String    @default("pending")
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?
}

// ═══════════════════════════════════════════
// REPUTATION MANAGEMENT
// ═══════════════════════════════════════════

model ReviewRequest {
  id             String    @id @default(cuid())
  organizationId String
  locationId     String?
  clientId       String?
  clientName     String?
  clientEmail    String?
  clientPhone    String?
  transactionId  String?
  channel        String
  status         String    @default("sent")
  rating         Int?
  feedback       String?
  pushedToGoogle Boolean   @default(false)
  pushedToYelp   Boolean   @default(false)
  sentAt         DateTime  @default(now())
  respondedAt    DateTime?
}

// ═══════════════════════════════════════════
// FORMS & WAIVERS
// ═══════════════════════════════════════════

model FormTemplate {
  id                String           @id @default(cuid())
  organizationId    String
  name              String
  type              String
  fields            Json
  isActive          Boolean          @default(true)
  requiresSignature Boolean          @default(false)
  createdAt         DateTime         @default(now())
  submissions       FormSubmission[]
}

model FormSubmission {
  id             String       @id @default(cuid())
  formTemplateId String
  formTemplate   FormTemplate @relation(fields: [formTemplateId], references: [id])
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])
  appointmentId  String?
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  data           Json
  signature      String?
  submittedAt    DateTime     @default(now())
}

// ═══════════════════════════════════════════
// PERMISSIONS
// ═══════════════════════════════════════════

model PermissionSet {
  id                 String              @id @default(cuid())
  organizationId     String?
  name               String
  permissions        String[]
  isSystem           Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  organization       Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users              User[]              @relation("UserCustomRole")
  groupsUsingThisSet OrganizationGroup[] @relation("GroupPermissionSet")

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ═══════════════════════════════════════════
// SETTINGS
// ═══════════════════════════════════════════

model BusinessSettings {
  id                   String       @id @default(cuid())
  organizationId       String       @unique
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  onlineBookingEnabled Boolean      @default(true)
  bookingLeadTime      Int          @default(60)
  bookingMaxAdvance    Int          @default(60)
  allowWalkIns         Boolean      @default(true)
  requireDeposit       Boolean      @default(false)
  depositPercentage    Float        @default(25)
  cancellationPolicy   String?
  cancellationWindow   Int          @default(24)
  cancellationFee      Float?
  sendConfirmations    Boolean      @default(true)
  sendReminders        Boolean      @default(true)
  reminderHours        Int          @default(24)
  sendReviewRequests   Boolean      @default(true)
  reviewRequestDelay   Int          @default(2)
  acceptCash           Boolean      @default(true)
  acceptCard           Boolean      @default(true)
  acceptGiftCard       Boolean      @default(true)
  taxRate              Float        @default(8.25)
  tipPromptEnabled     Boolean      @default(true)
  tipOptions           Json         @default("[15, 20, 25]")
  receiptFooter        String?
  receiptLogo          Boolean      @default(true)
  autoSendReceipt      Boolean      @default(true)
  loyaltyEnabled       Boolean      @default(false)
  googlePlaceId        String?
  yelpBusinessId       String?
  autoRequestReviews   Boolean      @default(true)
  minRatingForGoogle   Int          @default(4)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

// ═══════════════════════════════════════════
// DATA IMPORT / MIGRATION
// ═══════════════════════════════════════════

model ImportJob {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  type           String
  status         String       @default("pending")
  fileName       String?
  totalRows      Int          @default(0)
  processedRows  Int          @default(0)
  successRows    Int          @default(0)
  failedRows     Int          @default(0)
  errors         Json?
  sourceSystem   String?
  createdAt      DateTime     @default(now())
  completedAt    DateTime?
}

// ═══════════════════════════════════════════
// DEVICES & KIOSK
// ═══════════════════════════════════════════

model Device {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  locationId     String
  location       Location     @relation(fields: [locationId], references: [id])
  name           String
  type           String
  deviceCode     String       @unique
  isActive       Boolean      @default(true)
  lastSeenAt     DateTime?
  createdAt      DateTime     @default(now())
}

// ═══════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════════
// AUDIT LOG
// ═══════════════════════════════════════════

model AuditLog {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  organizationId String?
  action         String
  entity         String?
  entityId       String?
  before         Json?
  after          Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())
  route          String?
  requestId      String?
  changedFields  String[]
  metadata       Json?

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([entity, entityId])
  @@index([userId, createdAt(sort: Desc)])
}

// ═══════════════════════════════════════════
// API KEYS & WEBHOOKS
// ═══════════════════════════════════════════

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  keyHash        String       @unique
  keyPrefix      String
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
}

model Webhook {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  url             String
  events          String[]
  secret          String
  isActive        Boolean      @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime     @default(now())
}

// ═══════════════════════════════════════════
// AI RECEPTIONIST
// ═══════════════════════════════════════════

model AiReceptionistConfig {
  id               String       @id @default(cuid())
  organizationId   String       @unique
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isEnabled        Boolean      @default(false)
  voiceId          String?
  greeting         String?
  businessHours    Json?
  handoffNumber    String?
  handoffEmail     String?
  capabilities     Json         @default("{\"booking\": true, \"reschedule\": true, \"cancel\": true, \"faq\": true}")
  callsHandled     Int          @default(0)
  callsTransferred Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model AiReceptionistCall {
  id             String   @id @default(cuid())
  organizationId String
  callerPhone    String?
  callerName     String?
  duration       Int?
  outcome        String?
  transcript     String?
  summary        String?
  rating         Int?
  recordingUrl   String?
  createdAt      DateTime @default(now())
}

// ═══════════════════════════════════════════
// MESSAGING
// ═══════════════════════════════════════════

model Message {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id])
  direction      String
  channel        String       @default("sms")
  content        String
  status         String       @default("sent")
  staffId        String?
  staff          Staff?       @relation(fields: [staffId], references: [id], onDelete: SetNull)
  isRead         Boolean      @default(false)
  sentAt         DateTime     @default(now())
  readAt         DateTime?
}

model SavedResponse {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  content        String
  category       String?
  createdAt      DateTime @default(now())
}
