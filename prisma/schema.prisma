  primaryService       Service       @relation(fields: [primaryServiceId], references: [id], onUpdate: NoAction)
  staff                Staff         @relation(fields: [staffId], references: [id], onUpdate: NoAction)

  @@index([clientId], map: "idx_recseries_client")
  @@index([lastGeneratedThrough], map: "idx_recseries_generate", where: raw("(status = 'ACTIVE'::text)"))
  @@index([organizationId, status], map: "idx_recseries_org")
  @@index([staffId, status], map: "idx_recseries_staff", where: raw("(status = 'ACTIVE'::text)"))
}

model CancellationPolicy {
