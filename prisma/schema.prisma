generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model OrganizationGroup {
  id              String              @id @default(cuid())
  name            String
  level           GroupLevel
  parentGroupId   String?
  permissionSetId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @default(now()) @updatedAt
  organizationId  String
  locations       Location[]
  organization    Organization        @relation("OrgGroups", fields: [organizationId], references: [id], onDelete: Cascade)
  parentGroup     OrganizationGroup?  @relation("GroupHierarchy", fields: [parentGroupId], references: [id])
  childGroups     OrganizationGroup[] @relation("GroupHierarchy")
  permissionSet   PermissionSet?      @relation("GroupPermissionSet", fields: [permissionSetId], references: [id])

  @@index([parentGroupId])
  @@index([level])
  @@index([permissionSetId])
  @@index([organizationId])
}

model Organization {
  id                     String                  @id @default(cuid())
  name                   String
  slug                   String                  @unique
  logoUrl                String?
  primaryColor           String?                 @default("#606E74")
  email                  String?
  phone                  String?
  website                String?
  address                String?
  city                   String?
  state                  String?
  zip                    String?
  country                String                  @default("US")
  timezone               String                  @default("America/Chicago")
  language               String                  @default("en")
  isFranchise            Boolean                 @default(false)
  franchiseFeeType       String?
  franchiseFeeValue      Float?
  techFeeType            String?
  techFeeValue           Float?
  marketingFeeType       String?
  marketingFeeValue      Float?
  parentOrgId            String?
  plan                   String                  @default("starter")
  planStatus             String                  @default("trial")
  trialEndsAt            DateTime?
  stripeCustomerId       String?
  stripeSubId            String?
  salonTransactId        String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  businessStructure      String?
  businessType           String?
  description            String?
  ein                    String?
  legalName              String?
  onboardingCompleted    Boolean                 @default(false)
  onboardingStep         Int                     @default(0)
  sourceSystem           String?
  stateOfFormation       String?
  teamSize               String?
  yearEstablished        Int?
  applicationStatus      String?                 @default("not_started")
  applicationSubmittedAt DateTime?
  avgTransaction         String?
  bankAccountHolder      String?
  bankAccountNumber      String?
  bankAccountType        String?
  bankRoutingNumber      String?
  dbaName                String?
  fundingSpeed           String?
  monthlyVolume          String?
  ownerAddress           String?
  ownerDob               String?
  ownerFirstName         String?
  ownerLastName          String?
  ownerSsnLast4          String?
  ownerTitle             String?
  ownershipPercentage    Int?
  paymentMethods         String[]
  verticalId             VerticalId              @default(salon)
  verticalConfigOverride Json?
  themeOverride          Json?
  planTier               PlanTier                @default(FREE)
  enabledAddons          String[]                @default([])
  planEffectiveAt        DateTime?
  defaultLocale          String                  @default("en-US")
  aiReceptionistConfig   AiReceptionistConfig?
  apiKeys                ApiKey[]
  appointments           Appointment[]
  backgroundChecks       BackgroundCheck[]
  businessSettings       BusinessSettings?
  campaigns              Campaign[]
  cancellationPolicies   CancellationPolicy[]
  carts                  Cart[]
  chairs                 Chair[]
  clients                Client[]
  colorFormulas          ColorFormula[]
  compensations          Compensation[]
  consentSignatures      ConsentSignature[]
  customFieldDefinitions CustomFieldDefinition[]
  customFieldValues      CustomFieldValue[]
  devices                Device[]
  emailTemplates         EmailTemplate[]
  employmentAgreements   EmploymentAgreement[]
  entityTags             EntityTag[]
  geolocationLogs        GeolocationLog[]
  giftCards              GiftCard[]
  importJobs             ImportJob[]
  inventoryDeductions    InventoryDeduction[]
  inventoryLevels        InventoryLevel[]
  inventoryReorderDrafts InventoryReorderDraft[]
  licenseVerifications   LicenseVerification[]
  locations              Location[]
  loyaltyProgram         LoyaltyProgram?
  marketingAutomations   MarketingAutomation[]
  marketingExecutions    MarketingExecution[]
  memberships            Membership[]
  messages               Message[]
  offlineQueues          OfflineQueue[]
  onboardingSessions     OnboardingSession[]
  orders                 Order[]
  parentOrg              Organization?           @relation("FranchiseHierarchy", fields: [parentOrgId], references: [id])
  childOrgs              Organization[]          @relation("FranchiseHierarchy")
  organizationGroups     OrganizationGroup[]     @relation("OrgGroups")
  payments               Payment[]
  permissionSets         PermissionSet[]
  products               Product[]
  productCategories      ProductCategory[]
  productVariants        ProductVariant[]
  ptoRequests            PtoRequest[]
  recurringSeries        RecurringSeries[]
  refunds                Refund[]
  services               Service[]
  staff                  Staff[]
  staffInvitations       StaffInvitation[]
  tags                   Tag[]
  taxRates               TaxRate[]
  tipDistributions       TipDistribution[]
  tipSplit               TipSplit?
  transactions           Transaction[]
  users                  User[]
  waitlistEntries        WaitlistEntry[]
  webhooks               Webhook[]
  agreementSignTokens    AgreementSignToken[]

  @@index([verticalId])
  @@index([planTier])
}

model User {
  id                          String                      @id @default(cuid())
  name                        String?
  email                       String                      @unique
  emailVerified               DateTime?
  emailVerifyToken            String?
  emailVerifyExp              DateTime?
  password                    String?
  image                       String?
  organizationId              String?
  locationId                  String?
  isActive                    Boolean                     @default(true)
  lastLoginAt                 DateTime?
  passwordResetToken          String?
  passwordResetExp            DateTime?
  twoFactorEnabled            Boolean                     @default(false)
  twoFactorSecret             String?
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
  role                        Role                        @default(STAFF)
  customRoleId                String?
  locale                      String?
  accounts                    Account[]
  bookedAppointments          Appointment[]               @relation("BookedByUser")
  statusChanges               AppointmentStatusHistory[]  @relation("StatusChangedByUser")
  auditLogs                   AuditLog[]
  createdCustomFieldDefs      CustomFieldDefinition[]     @relation("CustomFieldDefinitionCreatedBy")
  updatedCustomFieldValues    CustomFieldValue[]          @relation("CustomFieldValueUpdatedBy")
  createdEntityTags           EntityTag[]                 @relation("EntityTagCreatedBy")
  createdFeatureFlags         FeatureFlag[]               @relation("FeatureFlagCreatedBy")
  updatedFeatureFlags         FeatureFlag[]               @relation("FeatureFlagUpdatedBy")
  featureFlagAudits           FeatureFlagAudit[]
  geolocationManagerOverrides GeolocationLog[]            @relation("GeolocationManagerOverride")
  geolocationLogs             GeolocationLog[]            @relation("GeolocationUser")
  inventoryReorderApprovals   InventoryReorderDraft[]     @relation("ReorderApprovedBy")
  notifications               Notification[]
  onboardingSessions          OnboardingSession[]         @relation("OnboardingSessionUser")
  onboardingTransitions       OnboardingStateTransition[] @relation("OnboardingTransitionUser")
  ptoDecisions                PtoRequest[]                @relation("PtoApprovedBy")
  refundsInitiated            Refund[]                    @relation("RefundInitiatedByUser")
  sessions                    Session[]
  staff                       Staff?                      @relation("UserStaff")
  sentInvitations             StaffInvitation[]           @relation("StaffInvitationInviter")
  acceptedInvitations         StaffInvitation[]           @relation("StaffInvitationAcceptedUser")
  createdTags                 Tag[]                       @relation("TagCreatedBy")
  customRole                  PermissionSet?              @relation("UserCustomRole", fields: [customRoleId], references: [id])
  organization                Organization?               @relation(fields: [organizationId], references: [id])

  @@index([customRoleId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Location {
  id                          String                  @id @default(cuid())
  organizationId              String
  name                        String
  address                     String?
  city                        String?
  state                       String?
  zip                         String?
  phone                       String?
  email                       String?
  timezone                    String                  @default("America/Chicago")
  isActive                    Boolean                 @default(true)
  taxRate                     Float                   @default(8.25)
  logoUrl                     String?
  coverImageUrl               String?
  lat                         Float?
  lng                         Float?
  geofenceRadius              Int                     @default(100)
  businessHours               Json?
  salonTransactLocationId     String?
  createdAt                   DateTime                @default(now())
  groupId                     String?
  appointments                Appointment[]
  bookingWindow               BookingWindow?
  cancellationPolicies        CancellationPolicy[]
  carts                       Cart[]
  chairs                      Chair[]
  clients                     Client[]
  devices                     Device[]
  geolocationLogs             GeolocationLog[]
  inventoryDeductions         InventoryDeduction[]    @relation("DeductionLocation")
  inventoryDeductionTransfers InventoryDeduction[]    @relation("DeductionTransferLocation")
  inventoryLevels             InventoryLevel[]
  inventoryReorderDrafts      InventoryReorderDraft[]
  group                       OrganizationGroup?      @relation(fields: [groupId], references: [id])
  organization                Organization            @relation(fields: [organizationId], references: [id])
  onboardingSessions          OnboardingSession[]
  orders                      Order[]
  recurringSeries             RecurringSeries[]
  services                    Service[]
  serviceLocations            ServiceLocation[]
  staff                       Staff[]
  staffInvitations            StaffInvitation[]
  stylistSchedules            StylistSchedule[]
  taxRates                    TaxRate[]
  transactions                Transaction[]
  waitlistEntries             WaitlistEntry[]

  @@index([groupId])
}

model Staff {
  id                    String                     @id @default(cuid())
  organizationId        String
  locationId            String
  userId                String?                    @unique
  name                  String
  email                 String?
  phone                 String?
  role                  String                     @default("stylist")
  jobTitle              String?
  commissionType        String                     @default("percentage")
  commissionRate        Float                      @default(40)
  isActive              Boolean                    @default(true)
  color                 String?
  bio                   String?
  avatarUrl             String?
  licenseNumber         String?
  licenseExpiry         DateTime?
  hireDate              DateTime?
  goals                 Json?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  softDeletedAt         DateTime?
  bufferOverrideMinutes Json?
  bookedAppointments    Appointment[]              @relation("BookedByStaff")
  appointments          Appointment[]
  appointmentItems      AppointmentItem[]
  statusChanges         AppointmentStatusHistory[] @relation("StatusChangedByStaff")
  backgroundChecks      BackgroundCheck[]
  cartItems             CartItem[]                 @relation("CartItemStaff")
  defaultChairs         Chair[]                    @relation("ChairDefaultStaff")
  clockEvents           ClockEvent[]
  colorFormulas         ColorFormula[]
  compensation          Compensation?
  employmentAgreements  EmploymentAgreement[]
  geolocationLogs       GeolocationLog[]           @relation("GeolocationStaff")
  inventoryDeductions   InventoryDeduction[]       @relation("DeductionStaff")
  licenseVerifications  LicenseVerification[]
  messages              Message[]
  orderItems            OrderItem[]                @relation("OrderItemStaff")
  performanceStats      PerformanceStat[]
  ptoRequests           PtoRequest[]
  recurringSeries       RecurringSeries[]
  refundsInitiated      Refund[]                   @relation("RefundInitiatedByStaff")
  serviceStaffOverrides ServiceStaffOverride[]
  location              Location                   @relation(fields: [locationId], references: [id])
  organization          Organization               @relation(fields: [organizationId], references: [id])
  user                  User?                      @relation("UserStaff", fields: [userId], references: [id])
  stylistSchedules      StylistSchedule[]
  scheduleExceptions    StylistScheduleException[]
  invitations           StaffInvitation[]
  stylistServices       StylistService[]
  tipDistributions      TipDistribution[]
  agreementSignTokens   AgreementSignToken[]

  @@index([organizationId, isActive], map: "idx_staff_org_active", where: raw("(\"softDeletedAt\" IS NULL)"))
}

/// Staff invitation lifecycle. Created when owner invites a stylist;
/// consumed when the invitee clicks the email link and creates their
/// User account. Token storage mirrors OnboardingVerificationToken
/// (hashed at rest, single-use via atomic consume).
///
/// This model contains row level security and requires additional setup
/// for migrations. Visit https://pris.ly/d/row-level-security for more info.
model StaffInvitation {
  id                String       @id @default(cuid())
  organizationId    String
  locationId        String
  staffId           String
  inviterUserId     String
  email             String
  name              String
  role              Role         @default(STAFF)
  tokenHash         String       @unique
  expiresAt         DateTime     @db.Timestamptz(6)
  acceptedAt        DateTime?    @db.Timestamptz(6)
  acceptedUserId    String?
  revokedAt         DateTime?    @db.Timestamptz(6)
  revokedReason     String?
  emailsSentCount   Int          @default(1)
  lastEmailSentAt   DateTime?    @db.Timestamptz(6)
  ipAddressIssued   String?
  ipAddressAccepted String?
  userAgentIssued   String?
  userAgentAccepted String?
  createdAt         DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  location          Location     @relation(fields: [locationId], references: [id], onUpdate: NoAction)
  staff             Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inviter           User         @relation("StaffInvitationInviter", fields: [inviterUserId], references: [id], onUpdate: NoAction)
  acceptedUser      User?        @relation("StaffInvitationAcceptedUser", fields: [acceptedUserId], references: [id], onUpdate: NoAction)

  @@index([organizationId, locationId, acceptedAt], map: "idx_staffinv_org_loc_pending", where: raw("(\"acceptedAt\" IS NULL AND \"revokedAt\" IS NULL)"))
  @@index([email], map: "idx_staffinv_email")
  @@index([expiresAt], map: "idx_staffinv_expires", where: raw("(\"acceptedAt\" IS NULL AND \"revokedAt\" IS NULL)"))
}

model ClockEvent {
  id             String   @id @default(cuid())
  staffId        String
  type           String
  timestamp      DateTime @default(now())
  lat            Float?
  lng            Float?
  withinGeofence Boolean  @default(false)
  ipAddress      String?
  staff          Staff    @relation(fields: [staffId], references: [id])
}

model PerformanceStat {
  id           String   @id @default(cuid())
  staffId      String
  periodStart  DateTime
  periodEnd    DateTime
  revenue      Float    @default(0)
  transactions Int      @default(0)
  tips         Float    @default(0)
  commission   Float    @default(0)
  rebooks      Int      @default(0)
  newClients   Int      @default(0)
  retailSales  Float    @default(0)
  createdAt    DateTime @default(now())
  staff        Staff    @relation(fields: [staffId], references: [id])
}

model Client {
  id                      String               @id @default(cuid())
  organizationId          String
  locationId              String?
  name                    String
  firstName               String?
  lastName                String?
  email                   String?
  phone                   String?
  altPhone                String?
  dateOfBirth             DateTime?
  gender                  String?
  address                 String?
  city                    String?
  state                   String?
  zip                     String?
  notes                   String?
  preferredStaffId        String?
  genderPref              String?
  referralSource          String?
  referredById            String?
  tags                    String[]
  isActive                Boolean              @default(true)
  marketingOptIn          Boolean              @default(false)
  smsOptIn                Boolean              @default(false)
  emailOptIn              Boolean              @default(false)
  loyaltyPoints           Int                  @default(0)
  totalSpent              Float                @default(0)
  visitCount              Int                  @default(0)
  lastVisitAt             DateTime?
  cardOnFile              Boolean              @default(false)
  stripeCustomerId        String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  allergies               Json?
  vipStatus               Boolean              @default(false)
  relationshipScore       Int                  @default(0)
  preferredLanguage       String               @default("en")
  preferredContactChannel String               @default("SMS")
  totalLifetimeValue      Int                  @default(0)
  softDeletedAt           DateTime?
  appointments            Appointment[]
  campaigns               CampaignRecipient[]
  carts                   Cart[]
  location                Location?            @relation(fields: [locationId], references: [id])
  organization            Organization         @relation(fields: [organizationId], references: [id])
  memberships             ClientMembership[]
  colorFormulas           ColorFormula[]
  consentSignatures       ConsentSignature[]
  familyMembers           FamilyMember[]
  formSubmissions         FormSubmission[]
  giftCards               GiftCard[]
  loyaltyHistory          LoyaltyEvent[]
  marketingExecutions     MarketingExecution[]
  messages                Message[]
  orders                  Order[]
  recurringSeries         RecurringSeries[]
  transactions            Transaction[]
  waitlistEntries         WaitlistEntry[]

  @@index([organizationId, isActive], map: "idx_client_org_active", where: raw("(\"softDeletedAt\" IS NULL)"))
  @@index([organizationId, email], map: "idx_client_org_email", where: raw("(\"softDeletedAt\" IS NULL)"))
  @@index([organizationId, phone], map: "idx_client_org_phone", where: raw("(\"softDeletedAt\" IS NULL)"))
}

model FamilyMember {
  id              String    @id @default(cuid())
  primaryClientId String
  name            String
  relationship    String?
  dateOfBirth     DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  primaryClient   Client    @relation(fields: [primaryClientId], references: [id])
}

model Service {
  id                        String                 @id @default(cuid())
  organizationId            String
  locationId                String?
  name                      String
  description               String?
  category                  String?
  price                     Float
  duration                  Int
  bufferTime                Int                    @default(0)
  isAddon                   Boolean                @default(false)
  addonAddsTime             Boolean                @default(false)
  maxAddonTime              Int?
  isActive                  Boolean                @default(true)
  taxable                   Boolean                @default(true)
  color                     String?
  imageUrl                  String?
  depositRequired           Boolean                @default(false)
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  productCost               Int?
  consumableCost            Int?
  targetMarginPct           Int?
  processingMinutes         Int?
  addOnVisibleOnBookingMenu Boolean                @default(true)
  bookableByCustomers       Boolean                @default(true)
  bookableByStaff           Boolean                @default(true)
  requiresConsultation      Boolean                @default(false)
  requiresConsent           Boolean                @default(false)
  softDeletedAt             DateTime?
  depositType               DepositType?
  depositValueCents         Int?
  appointments              Appointment[]
  appointmentItems          AppointmentItem[]
  cancellationPolicies      CancellationPolicy[]
  cartItems                 CartItem[]
  consentSignatures         ConsentSignature[]
  orderItems                OrderItem[]
  recurringSeries           RecurringSeries[]
  location                  Location?              @relation(fields: [locationId], references: [id])
  organization              Organization           @relation(fields: [organizationId], references: [id])
  serviceLocations          ServiceLocation[]
  serviceStaffOverrides     ServiceStaffOverride[]
  stylistServices           StylistService[]

  @@index([organizationId, isAddon, isActive], map: "idx_service_org_addon")
  @@index([organizationId, locationId, isActive], map: "idx_service_org_loc_active", where: raw("(\"softDeletedAt\" IS NULL)"))
}

model ServiceLocation {
  id                      String   @id @default(cuid())
  serviceId               String
  locationId              String
  priceOverrideCents      Int?
  durationOverrideMinutes Int?
  isAvailable             Boolean  @default(true)
  pendingPriceApproval    Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @default(now()) @updatedAt
  location                Location @relation(fields: [locationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  service                 Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([serviceId, locationId])
  @@index([locationId], map: "idx_servicelocation_location")
  @@index([serviceId], map: "idx_servicelocation_service")
}

model ServiceStaffOverride {
  id              String   @id @default(cuid())
  serviceId       String
  staffId         String
  priceCents      Int?
  durationMinutes Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  service         Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff           Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([serviceId, staffId])
  @@index([serviceId], map: "idx_servicestaff_service")
  @@index([staffId], map: "idx_servicestaff_staff")
}

model StylistService {
  id         String   @id @default(cuid())
  staffId    String
  serviceId  String
  skillLevel String?
  createdAt  DateTime @default(now())
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([staffId, serviceId])
  @@index([serviceId], map: "idx_stylistservice_service")
  @@index([staffId], map: "idx_stylistservice_staff")
}

model ColorFormula {
  id                  String               @id @default(cuid())
  organizationId      String
  clientId            String
  appointmentId       String?
  staffId             String
  formulaVersion      Int                  @default(1)
  formulaIngredients  Json
  processingMinutes   Int?
  resultNotes         String?
  beforePhotoUrl      String?
  afterPhotoUrl       String?
  allergyChecked      Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @default(now()) @updatedAt
  appointment         Appointment?         @relation(fields: [appointmentId], references: [id], onUpdate: NoAction)
  client              Client               @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff               Staff                @relation(fields: [staffId], references: [id], onUpdate: NoAction)
  inventoryDeductions InventoryDeduction[]

  @@index([appointmentId], map: "idx_colorformula_appointment", where: raw("(\"appointmentId\" IS NOT NULL)"))
  @@index([clientId, createdAt(sort: Desc)], map: "idx_colorformula_client_created")
  @@index([organizationId], map: "idx_colorformula_org")
}

/// Immutable audit record — signatures don't change after creation. No updatedAt field intentional.
model ConsentSignature {
  id               String       @id @default(cuid())
  organizationId   String
  clientId         String
  serviceId        String?
  consentType      String
  signedAt         DateTime     @default(now())
  signedDocUrl     String?
  signatureDataUrl String?
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime?
  client           Client       @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  service          Service?     @relation(fields: [serviceId], references: [id], onUpdate: NoAction)

  @@index([clientId, signedAt(sort: Desc)], map: "idx_consent_client")
  @@index([organizationId], map: "idx_consent_org")
}

model StylistSchedule {
  id                 String    @id @default(cuid())
  staffId            String
  locationId         String
  dayOfWeek          Int
  startTime          DateTime  @db.Time(6)
  endTime            DateTime  @db.Time(6)
  isWorking          Boolean   @default(true)
  effectiveStartDate DateTime  @db.Date
  effectiveEndDate   DateTime? @db.Date
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt
  location           Location  @relation(fields: [locationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff              Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([staffId, dayOfWeek, effectiveStartDate])
  @@index([locationId], map: "idx_stylistsched_location")
  @@index([staffId, dayOfWeek], map: "idx_stylistsched_staff_day")
  @@index([staffId, effectiveStartDate, effectiveEndDate], map: "idx_stylistsched_staff_eff")
}

model StylistScheduleException {
  id        String    @id @default(cuid())
  staffId   String
  date      DateTime  @db.Date
  startTime DateTime? @db.Time(6)
  endTime   DateTime? @db.Time(6)
  isWorking Boolean   @default(false)
  reason    String?
  createdAt DateTime  @default(now())
  staff     Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([staffId, date])
  @@index([staffId, date], map: "idx_schedexc_staff_date")
}

model Appointment {
  id                          String                     @id @default(cuid())
  organizationId              String
  locationId                  String
  clientId                    String?
  staffId                     String
  serviceId                   String?
  clientName                  String?
  serviceName                 String?
  price                       Float?
  depositPaid                 Float                      @default(0)
  status                      String                     @default("scheduled")
  startTime                   DateTime
  endTime                     DateTime
  notes                       String?
  internalNotes               String?
  isWalkIn                    Boolean                    @default(false)
  checkoutCode                String?                    @unique
  checkedInAt                 DateTime?
  completedAt                 DateTime?
  cancelledAt                 DateTime?
  cancelReason                String?
  reminderSent                Boolean                    @default(false)
  confirmationSent            Boolean                    @default(false)
  rebookedFrom                String?
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt
  seriesId                    String?
  bookingSource               String                     @default("STAFF")
  bookedByUserId              String?
  bookedByStaffId             String?
  preAuthHoldCents            Int?
  preAuthHoldStatus           String?
  /// Pre-auth transaction ID from SalonTransact (which routes to Payroc or future processors).
  /// Processor-agnostic naming intentional — Kasse calls SalonTransact, not Payroc directly.
  preAuthHoldTxId             String?
  noShowFeeAppliedCents       Int?
  cancellationFeeAppliedCents Int?
  consentSignatureIds         String[]                   @default([])
  estimatedTotalCents         Int?
  estimatedTotalMinutes       Int?
  isFirstVisit                Boolean                    @default(false)
  formulaIds                  String[]                   @default([])
  softDeletedAt               DateTime?
  bookedByStaff               Staff?                     @relation("BookedByStaff", fields: [bookedByStaffId], references: [id], onUpdate: NoAction)
  bookedByUser                User?                      @relation("BookedByUser", fields: [bookedByUserId], references: [id], onUpdate: NoAction)
  client                      Client?                    @relation(fields: [clientId], references: [id])
  location                    Location                   @relation(fields: [locationId], references: [id])
  organization                Organization               @relation(fields: [organizationId], references: [id])
  series                      RecurringSeries?           @relation(fields: [seriesId], references: [id], onUpdate: NoAction)
  service                     Service?                   @relation(fields: [serviceId], references: [id])
  staff                       Staff                      @relation(fields: [staffId], references: [id])
  addons                      AppointmentAddon[]
  items                       AppointmentItem[]
  statusHistory               AppointmentStatusHistory[]
  carts                       Cart[]
  colorFormulas               ColorFormula[]
  formSubmissions             FormSubmission[]
  inventoryDeductions         InventoryDeduction[]
  marketingExecutions         MarketingExecution[]       @relation("ConvertedAppointment")
  orders                      Order[]
  tipDistributions            TipDistribution[]

  @@index([clientId], map: "idx_appointment_client", where: raw("(\"clientId\" IS NOT NULL)"))
  @@index([organizationId, locationId, startTime], map: "idx_appointment_org_loc_start")
  @@index([organizationId, bookingSource], map: "idx_appointment_org_source")
  @@index([organizationId, staffId, startTime], map: "idx_appointment_org_staff_start")
  @@index([seriesId], map: "idx_appointment_series", where: raw("(\"seriesId\" IS NOT NULL)"))
  @@index([organizationId, locationId, startTime], map: "idx_appointment_softdel", where: raw("(\"softDeletedAt\" IS NULL)"))
}

model AppointmentItem {
