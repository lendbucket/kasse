}

model RecurringSeries {
  id                   String        @id @default(cuid())
  organizationId       String
  locationId           String
  clientId             String
  staffId              String
  primaryServiceId     String
  frequency            String
  customIntervalDays   Int?
  dayOfWeek            Int?
  preferredTime        DateTime      @db.Time(6)
  startDate            DateTime      @db.Date
  endDate              DateTime?     @db.Date
  maxOccurrences       Int?
  occurrencesGenerated Int           @default(0)
  lastGeneratedThrough DateTime?     @db.Date
  status               String        @default("ACTIVE")
  pausedReason         String?
  pausedUntil          DateTime?     @db.Date
  notes                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @default(now()) @updatedAt
  appointments         Appointment[]
  client               Client        @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: NoAction)
