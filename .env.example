# Kasse — required environment variables
# Copy this to .env.local and fill in real values.

# Database (Supabase pooled connection)
DATABASE_URL="postgresql://user:password@host:5432/postgres"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple Sign-In (P1.A.9)
# Get these from https://developer.apple.com/account/resources
# Authorized redirect URI: ${NEXTAUTH_URL}/api/auth/callback/apple
# - APPLE_CLIENT_ID: Services ID (looks like com.kasseapp.web)
# - APPLE_TEAM_ID: Apple Developer Team ID (10-char alphanumeric)
# - APPLE_KEY_ID: Key ID for the signing key (10-char alphanumeric)
# - APPLE_PRIVATE_KEY: Private key PEM content. Apple has standardized on
#     PKCS#8 format since ~2020, so new .p8 files start with
#     "-----BEGIN PRIVATE KEY-----". Legacy keys in SEC1 format
#     ("-----BEGIN EC PRIVATE KEY-----") are also accepted by jsonwebtoken's
#     ES256 signing. Include the BEGIN/END lines exactly as Apple provides.
#   In Vercel, paste the full multi-line PEM as a single string with \n escapes.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# P1.A.13: Rate limiting via Upstash Redis.
# Sign up at https://upstash.com (free tier covers 10K commands/day).
# Create a Redis database in us-east-1 (closest to Vercel us-east-2).
# Without these set, lib/rate-limit/client.ts fail-opens (logs a startup
# warning, allows all requests through). Production MUST have these set.
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-rest-token

# Anthropic (AI features)
ANTHROPIC_API_KEY=""

# Resend (transactional email)
RESEND_API_KEY=""

# Stripe (payments)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""

# Sentry (production observability)
# To enable Sentry in production:
# 1. Create a Sentry project at https://sentry.io
# 2. Choose "Next.js" platform
# 3. Copy the DSN to Vercel env vars (Production scope):
#    - NEXT_PUBLIC_SENTRY_DSN (client-side)
#    - SENTRY_DSN (server + edge)
# 4. For source map uploads (recommended), create an internal integration:
#    - SENTRY_ORG = your-org-slug
#    - SENTRY_PROJECT = your-project-slug
#    - SENTRY_AUTH_TOKEN = auth token with project:releases scope
# 5. Deploy. Trigger a test error to verify capture.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_PREVIEW_ENABLED=false
SENTRY_PREVIEW_ENABLED=false

# Public status page (BetterStack)
NEXT_PUBLIC_BETTERSTACK_STATUS_URL=

# Onboarding resume tokens (generate with: openssl rand -hex 32)
ONBOARDING_RESUME_SECRET=

# Magic-link verification base URL (signup.kasseapp.com in prod)
NEXT_PUBLIC_ONBOARDING_BASE_URL=https://signup.kasseapp.com
